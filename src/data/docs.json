[
  {
    "id": "html-table",
    "topic": "html",
    "kind": "element",
    "title": "table",
    "keywords": ["table", "tabular data", "thead", "tbody", "th", "td"],
    "summary": "Use the table element for tabular data with meaningful row and column relationships. Pair it with caption, thead, tbody, and th for accessible structure.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/table",
    "sourceLabel": "MDN HTML Reference",
    "sourceType": "guide",
    "specUrl": "https://html.spec.whatwg.org/dev/tables.html#the-table-element",
    "specLabel": "WHATWG HTML Standard",
    "anchors": ["tabular data", "caption", "thead", "tbody", "accessible headers"],
    "exampleSnippet": "<table>\n  <caption>Weekly schedule</caption>\n  <thead>\n    <tr><th>Day</th><th>Topic</th></tr>\n  </thead>\n  <tbody>\n    <tr><td>Monday</td><td>Forms</td></tr>\n  </tbody>\n</table>"
  },
  {
    "id": "html-form",
    "topic": "html",
    "kind": "element",
    "title": "form",
    "keywords": ["form", "submit", "input", "fieldset", "label"],
    "summary": "Use the form element to collect and submit user input. Structure controls with label, fieldset, and button to keep forms understandable and accessible.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/form",
    "sourceLabel": "MDN HTML Reference",
    "sourceType": "guide",
    "specUrl": "https://html.spec.whatwg.org/dev/forms.html#the-form-element",
    "specLabel": "WHATWG HTML Standard",
    "anchors": ["form controls", "submit lifecycle", "field grouping"],
    "exampleSnippet": "<form>\n  <label>\n    Email\n    <input type=\"email\" name=\"email\" required />\n  </label>\n  <button type=\"submit\">Subscribe</button>\n</form>"
  },
  {
    "id": "html-dialog",
    "topic": "html",
    "kind": "element",
    "title": "dialog",
    "keywords": ["dialog", "modal", "showModal", "popover"],
    "summary": "The dialog element provides a semantic container for modal and non-modal dialogs. It works well for confirmation flows and focused interactions.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/dialog",
    "sourceLabel": "MDN HTML Reference",
    "sourceType": "guide",
    "specUrl": "https://html.spec.whatwg.org/dev/interactive-elements.html#the-dialog-element",
    "specLabel": "WHATWG HTML Standard",
    "anchors": ["modal dialogs", "close events", "showModal"],
    "exampleSnippet": "<dialog id=\"help-dialog\">\n  <p>Review your selectors before submitting.</p>\n  <form method=\"dialog\">\n    <button>Close</button>\n  </form>\n</dialog>"
  },
  {
    "id": "html-section",
    "topic": "html",
    "kind": "element",
    "title": "section",
    "keywords": ["section", "landmark", "heading", "document outline"],
    "summary": "Use section for thematic groupings of content that deserve a heading. It should not replace generic layout wrappers that have no semantic meaning.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/section",
    "sourceLabel": "MDN HTML Reference",
    "sourceType": "guide",
    "specUrl": "https://html.spec.whatwg.org/dev/sections.html#the-section-element",
    "specLabel": "WHATWG HTML Standard",
    "anchors": ["thematic grouping", "headings", "document structure"],
    "exampleSnippet": "<section>\n  <h2>Selectors to practice</h2>\n  <p>Work through descendant, child, and attribute selectors.</p>\n</section>"
  },
  {
    "id": "css-display",
    "topic": "css",
    "kind": "property",
    "title": "display",
    "keywords": ["display", "block", "inline", "flex", "grid", "layout"],
    "summary": "The display property defines how an element generates boxes and participates in layout. It is the entry point for block, inline, flex, grid, and more.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/CSS/display",
    "sourceLabel": "MDN CSS Reference",
    "sourceType": "guide",
    "specUrl": "https://drafts.csswg.org/css-display/#the-display-properties",
    "specLabel": "CSS Display Module Level 3",
    "anchors": ["outer display", "inner display", "flex", "grid"],
    "exampleSnippet": ".cards {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 1rem;\n}"
  },
  {
    "id": "css-grid-template-columns",
    "topic": "css",
    "kind": "property",
    "title": "grid-template-columns",
    "keywords": ["grid-template-columns", "grid", "tracks", "repeat", "minmax"],
    "summary": "Use grid-template-columns to define the track sizing of a CSS grid. Functions like repeat and minmax make responsive columns easier to express.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/CSS/grid-template-columns",
    "sourceLabel": "MDN CSS Reference",
    "sourceType": "guide",
    "specUrl": "https://drafts.csswg.org/css-grid/#propdef-grid-template-columns",
    "specLabel": "CSS Grid Layout",
    "anchors": ["track sizing", "repeat()", "minmax()"],
    "exampleSnippet": ".gallery {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));\n}"
  },
  {
    "id": "css-focus-visible",
    "topic": "css",
    "kind": "selector",
    "title": ":focus-visible",
    "keywords": [":focus-visible", "focus ring", "keyboard navigation", "accessibility"],
    "summary": "Use :focus-visible to style focus only when the browser determines a visible indicator is helpful, especially for keyboard users.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/CSS/:focus-visible",
    "sourceLabel": "MDN CSS Reference",
    "sourceType": "guide",
    "specUrl": "https://drafts.csswg.org/selectors/#the-focus-visible-pseudo",
    "specLabel": "Selectors Level 4",
    "anchors": ["keyboard focus", "focus ring", "accessibility"],
    "exampleSnippet": "button:focus-visible {\n  outline: 3px solid #0b57d0;\n  outline-offset: 3px;\n}"
  },
  {
    "id": "css-media",
    "topic": "css",
    "kind": "at-rule",
    "title": "@media",
    "keywords": ["@media", "responsive design", "media query", "breakpoints"],
    "summary": "Use @media to apply styles based on viewport size, user preferences, and other media features. It is essential for responsive and adaptive design.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/CSS/@media",
    "sourceLabel": "MDN CSS Reference",
    "sourceType": "guide",
    "specUrl": "https://drafts.csswg.org/mediaqueries/#media",
    "specLabel": "Media Queries Level 5",
    "anchors": ["viewport breakpoints", "prefers-color-scheme", "responsive patterns"],
    "exampleSnippet": "@media (max-width: 960px) {\n  .layout {\n    grid-template-columns: 1fr;\n  }\n}"
  },
  {
    "id": "javascript-array-map",
    "topic": "javascript",
    "kind": "method",
    "title": "Array.prototype.map",
    "keywords": ["array", "map", "transform", "iteration", "callback"],
    "summary": "Use Array.prototype.map to transform each item in an array and produce a new array. It is ideal when you want a one-to-one value transformation.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Array/map",
    "sourceLabel": "MDN JavaScript Reference",
    "sourceType": "guide",
    "specUrl": "https://tc39.es/ecma262/multipage/indexed-collections.html#sec-array.prototype.map",
    "specLabel": "ECMAScript Standard",
    "anchors": ["transformation", "callback", "immutable array workflows"],
    "exampleSnippet": "const tags = ['html', 'css', 'javascript'];\nconst badges = tags.map((tag) => tag.toUpperCase());"
  },
  {
    "id": "javascript-promise",
    "topic": "javascript",
    "kind": "object",
    "title": "Promise",
    "keywords": ["promise", "async", "then", "catch", "finally"],
    "summary": "Promise represents an eventual completion or failure of an asynchronous task. It helps structure async workflows and compose dependent steps.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise",
    "sourceLabel": "MDN JavaScript Reference",
    "sourceType": "guide",
    "specUrl": "https://tc39.es/ecma262/multipage/control-abstraction-objects.html#sec-promise-objects",
    "specLabel": "ECMAScript Standard",
    "anchors": ["then chains", "error handling", "microtasks"],
    "exampleSnippet": "fetch('/topics.json')\n  .then((response) => response.json())\n  .then((data) => console.log(data))\n  .catch((error) => console.error(error));"
  },
  {
    "id": "javascript-query-selector",
    "topic": "javascript",
    "kind": "method",
    "title": "Document.querySelector",
    "keywords": ["querySelector", "selector", "DOM", "element lookup"],
    "summary": "Use querySelector to locate the first element that matches a CSS selector. It is one of the most common DOM querying APIs.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/API/Document/querySelector",
    "sourceLabel": "MDN Web API Reference",
    "sourceType": "guide",
    "specUrl": "https://dom.spec.whatwg.org/#ref-for-dom-parentnode-queryselector",
    "specLabel": "DOM Standard",
    "anchors": ["css selectors", "DOM lookup", "first match"],
    "exampleSnippet": "const openButton = document.querySelector('[data-open-dialog]');"
  },
  {
    "id": "javascript-add-event-listener",
    "topic": "javascript",
    "kind": "method",
    "title": "EventTarget.addEventListener",
    "keywords": ["addEventListener", "event", "listener", "DOM events", "click"],
    "summary": "Use addEventListener to react to browser and user events without overwriting other handlers. It is the core event subscription API on the web platform.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/API/EventTarget/addEventListener",
    "sourceLabel": "MDN Web API Reference",
    "sourceType": "guide",
    "specUrl": "https://dom.spec.whatwg.org/#dom-eventtarget-addeventlistener",
    "specLabel": "DOM Standard",
    "anchors": ["event listeners", "options object", "capture phase"],
    "exampleSnippet": "button.addEventListener('click', () => {\n  console.log('Practice button clicked');\n});"
  },
  {
    "id": "javascript-map-object",
    "topic": "javascript",
    "kind": "object",
    "title": "Map",
    "keywords": ["map object", "key value", "collection", "iteration"],
    "summary": "Map stores key-value pairs while preserving insertion order. It is useful when keys are not limited to strings and when predictable iteration matters.",
    "sourceUrl": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Map",
    "sourceLabel": "MDN JavaScript Reference",
    "sourceType": "guide",
    "specUrl": "https://tc39.es/ecma262/multipage/keyed-collections.html#sec-map-objects",
    "specLabel": "ECMAScript Standard",
    "anchors": ["keyed collections", "iteration order", "object vs map"],
    "exampleSnippet": "const progress = new Map([\n  ['HTML', 4],\n  ['CSS', 3],\n  ['JavaScript', 2]\n]);"
  }
]
